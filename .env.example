# ============================================================================
# .env.example — environment template
#
# Authorized by: spec Part 29 (Environment Variables).
#
# Copy this file to `.env` and fill in the values that apply to your host.
# Never commit `.env` — it is in .gitignore.
#
# Each variable is grouped by the component that consumes it. Every agent
# accepts the "common" block.
# ============================================================================

# --- common (every agent consumes these) ---
LOG_LEVEL=info
NATS_URL=nats://nats:4222
REDIS_URL=redis://redis:6379
CLICKHOUSE_URL=http://clickhouse:8123
LEDGER_PATH=/data/ledger
SCHEMA_VERSION=1.0.0

# --- agent identity (override per-container in docker-compose.yml) ---
AGENT_ID=
CITY=
ROLE=

# --- chronos ---
# Frequency (in ms) of the HLC tick publication on chronos.time.oracle.
CHRONOS_TICK_INTERVAL_MS=1000

# --- collector-equities-csv ---
# Path inside the container to the fixture CSV. Mounted read-only from
# ./tests/fixtures/ on the host.
CSV_FIXTURE_PATH=/fixtures/aapl_2023-03-13_1min.csv
# Playback speed multiplier. 1.0 = real-time; 1000.0 = one trading day in
# 23 seconds. Useful for acceptance tests.
CSV_PLAYBACK_SPEED=1000.0

# --- paper-executor (Alpaca paper trading) ---
# Get these from https://alpaca.markets/ after creating a paper account.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- risk-overlord ---
# Hard limits are pounded in at M0; M3 introduces dynamic limits.
RISK_MAX_GROSS_EXPOSURE_USD_CENTS=1000000000   # $10,000
RISK_MAX_POSITION_USD_CENTS=250000000          # $2,500 per symbol
RISK_MAX_DAILY_LOSS_USD_CENTS=150000000        # $1,500 / day
# How often to re-evaluate limits.
RISK_EVAL_INTERVAL_MS=100

# --- tape-recorder ---
TAPE_BATCH_SIZE=1000
TAPE_BATCH_INTERVAL_MS=1000
TAPE_CLICKHOUSE_DB=obsidian
TAPE_CLICKHOUSE_TABLE=tape

# --- visualization ---
# URL the browser uses to reach the NATS WebSocket gateway. For local
# development this is the host-mapped port of the nats container.
VITE_NATS_WS_URL=ws://localhost:8080

# --- deferred, present here for documentation ---
# ANTHROPIC_API_KEY=           # M6+ executive narrative synthesis
# VAULT_ADDR=                  # M3+ identity service
# QDRANT_URL=                  # M1+ vector memory
# NEO4J_URI=                   # M1+ knowledge graph
# POSTGRES_URL=                # M1+ TimescaleDB + AGE
# MINIO_ENDPOINT=              # M1+ ledger archival
